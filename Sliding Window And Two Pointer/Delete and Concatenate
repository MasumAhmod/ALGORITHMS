void solve() {
    int n , k;
    cin >> n >> k;

    vector <int> v(n);
    for(int i = 0; i < n; ++i) {
        cin >> v[i];
    }

    sort(v.begin() , v.end());
    int l = 0 , r = n - 1;
    int cnt = 0;

    int ans = 0;
    while(l <= r) {
        if(v[l] >= k) {
            ans += v[l];
            l++;
            cnt++;
        } else {
            ans += (max(v[l] , v[r]));
            l++;
            r--;
            cnt++;
        }
    }

    // cout << ans << endl;

    k *= cnt;
    cout << (ans - k) << endl;
} 

int32_t main()
{
    Start

    int t = 0;
    cin >> t;

    // solve();

    while (t--)
    {
        solve();
    }

    return 0;
}
